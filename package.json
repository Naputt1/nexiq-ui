{
  "name": "@nexiq/ui",
  "private": false,
  "version": "1.0.0",
  "description": "React component structure visualizer",
  "author": "naputt",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "./scripts/build-electron.sh",
    "build:wasm": "cd layout-wasm && pnpm exec wasm-pack build --target web",
    "build:vite": "tsc || true && vite build",
    "build:coverage": "VITE_COVERAGE=true pnpm build:vite",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:coverage": "pnpm build:coverage && pnpm test:e2e && tsx e2e/merge-coverage.ts",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "pnpm run rebuild"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/tmp": "^0.2.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "konva": "^10.2.3",
    "lucide-react": "^1.7.0",
    "nyc": "^18.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "react-scan": "^0.5.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-istanbul": "^8.0.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.2",
    "wasm-pack": "^0.14.0"
  },
  "dependencies": {
    "@nexiq/component-extension": "file:../nexiq/packages/component-extension",
    "@nexiq/extension-sdk": "file:../nexiq/packages/extension-sdk",
    "@nexiq/file-extension": "file:../nexiq/packages/file-extension",
    "@nexiq/git-extension": "file:../nexiq/packages/git-extension",
    "@nexiq/layout-wasm": "file:./layout-wasm/pkg",
    "@nexiq/shared": "file:../nexiq/packages/shared",
    "@node-rs/xxhash": "^1.7.6",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.1",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "12.8.0",
    "fast-glob": "^3.3.3",
    "flatbuffers": "^25.9.23",
    "js-yaml": "^4.1.1",
    "lodash.debounce": "^4.0.8",
    "pixi-viewport": "^6.0.3",
    "pixi.js": "^8.17.1",
    "radix-ui": "^1.4.3",
    "react-resizable-panels": "^4.9.0",
    "simple-git": "^3.33.0",
    "tmp": "^0.2.5",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "bundledDependencies": [
    "@node-rs/xxhash"
  ]
}
